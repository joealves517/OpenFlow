# VidFlow (OpenFlow) - Public Environment Variables Template
# Copy this file to '.env' and fill in your custom API keys for local development.

# Pexels API Key - Used for client-side search of royalty-free stock photos & videos.
# Obtain a free key from: https://www.pexels.com/api/
VITE_PEXELS_API_KEY=your_pexels_api_key_here

# Support Contact Form Webhook - Google Apps Script URL to handle contact requests.
# Set up a Google Apps Script that appends to Google Sheets and sends notifications.
VITE_SUPPORT_WEBHOOK_URL=your_google_apps_script_webhook_url_here

# Supabase Auth Configuration (Client-side)
# If left empty, VidFlow operates in a fully functional mock offline-mode for local testing.
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
