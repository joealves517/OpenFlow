    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.1",
    "@types/three": "^0.184.0",
    "atropos": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "goey-toast": "^0.4.0",
    "gsap": "^3.15.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.563.0",
    "mediabunny": "^1.34.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
